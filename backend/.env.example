# Copy this file to .env and fill in your real values. Never commit .env.
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://researchai:researchai@localhost:5432/researchai

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Groq (required) ───────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# ── Optional academic API keys ────────────────────────────────────────────────
# Without these, the agent falls back to Selenium scraping for that source.
IEEE_API_KEY=
SPRINGER_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# ── Selenium (set automatically in Docker via docker-compose) ─────────────────
# Leave blank for local dev; webdriver-manager will auto-download the driver.
CHROME_BIN=
CHROMEDRIVER_PATH=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
